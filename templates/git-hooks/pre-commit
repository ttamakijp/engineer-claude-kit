#!/usr/bin/env bash
# pre-commit hook - leak detection
# Distributed by engineer-claude-kit (Group C). Overwrite-safe runtime artifact.
set -euo pipefail

fail=0

# 1. gitleaks staged scan (only if gitleaks is on PATH)
if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks protect --staged --redact -v; then
        echo "[pre-commit] gitleaks detected potential secrets. Commit blocked." >&2
        fail=1
    fi
else
    echo "[pre-commit] gitleaks not found, skipping leak scan" >&2
fi

# 2. Minimal PII / credential regex check on staged ADDED lines (lines starting with '+').
staged_added="$(git diff --cached --no-color --unified=0 | grep '^+' | grep -v '^+++' || true)"

if [ -n "$staged_added" ]; then
    # Email addresses
    if printf '%s\n' "$staged_added" | grep -Eiq '[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}'; then
        echo "[pre-commit] possible email address in staged changes." >&2
        fail=1
    fi
    # Phone numbers (international / hyphenated, 10+ digits grouped)
    if printf '%s\n' "$staged_added" | grep -Eq '(\+?[0-9]{1,3}[-. ]?)?(\([0-9]{2,4}\)[-. ]?)?[0-9]{2,4}[-. ][0-9]{2,4}[-. ][0-9]{3,4}'; then
        echo "[pre-commit] possible phone number in staged changes." >&2
        fail=1
    fi
    # API-key-like tokens: AWS AKIA, Anthropic sk-ant-, OpenAI sk-
    if printf '%s\n' "$staged_added" | grep -Eq 'AKIA[0-9A-Z]{16}|sk-ant-[A-Za-z0-9_-]{20,}|sk-[A-Za-z0-9]{20,}'; then
        echo "[pre-commit] possible API key in staged changes." >&2
        fail=1
    fi
fi

if [ "$fail" -ne 0 ]; then
    echo "[pre-commit] leak check FAILED. Use 'git commit --no-verify' only if you are certain." >&2
    exit 1
fi

exit 0